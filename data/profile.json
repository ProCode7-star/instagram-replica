#include <iostream>
#include <fstream>
#include <string>

std::string obtenerUsuarioPublico() {
    std::ifstream archivo("data/profile.json");
    std::string linea;
    std::string nombre = "Desconocido";

    if (archivo.is_open()) {
        while (std::getline(archivo, linea)) {
            // Buscamos la clave exacta "handle"
            if (linea.find("\"handle\"") != std::string::npos) {
                // Buscamos dónde empieza el valor después de los dos puntos
                size_t inicio = linea.find(": \"") + 3;
                // Buscamos el final de la cadena (la siguiente comilla)
                size_t fin = linea.find("\"", inicio);
                
                if (inicio != std::string::npos && fin != std::string::npos) {
                    nombre = linea.substr(inicio, fin - inicio);
                }
                break;
            }
        }
        archivo.close();
    }
    return nombre;
}
